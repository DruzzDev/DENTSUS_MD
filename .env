# === DRUZZ XD CONFIGURATION ===

# Command prefix
PREFIX=.

# Baileys session folder
AUTH_DIR=auth_baileys

# Your WhatsApp number (international format, no +, e.g. 18294383885)
NUMBER=18294383885

# Connect via QR code (true) or pairing code (false)
USE_QR=false

# Log level: silent | error | warn | info | debug
LOG_LEVEL=silent

# Reconnect delay in ms
RECONNECT_DELAY=5000

# Comma-separated list of known bot phone numbers for the antiBot protection
# (WhatsApp does not expose a way to auto-detect bot accounts, so this list
# has to be maintained manually). Leave empty to disable that check.
KNOWN_BOT_NUMBERS=
